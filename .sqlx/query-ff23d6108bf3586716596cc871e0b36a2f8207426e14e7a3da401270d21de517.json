  "query": "\n            SELECT m.id AS \"id!\", m.sender AS \"sender!\", m.recipient,\n                   m.content AS \"content!\", m.timestamp AS \"timestamp!\"\n            FROM messages m\n            JOIN room_messages rm ON rm.message_id = m.id\n            WHERE rm.room_id = ?\n            ORDER BY m.id DESC\n            LIMIT ?\n            ",
