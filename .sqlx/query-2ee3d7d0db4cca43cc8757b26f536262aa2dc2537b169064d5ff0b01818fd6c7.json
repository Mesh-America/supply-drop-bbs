  "query": "\n            SELECT id AS \"id!\", sender AS \"sender!\", recipient,\n                   content AS \"content!\", timestamp AS \"timestamp!\"\n            FROM messages\n            WHERE (sender = ? OR recipient = ?)\n              AND recipient IS NOT NULL\n              AND id > ?\n            ORDER BY id\n            LIMIT ?\n            ",
