#!/bin/sh
# postinst — Supply Drop BBS Debian post-install script
#
# $1 = "configure"           on a fresh install
# $1 = "configure" $2 = old  on an upgrade from version $2
set -e

case "$1" in
  configure)
    # ── Create the service account if it doesn't already exist ──────────────
    if ! id -u supply-drop >/dev/null 2>&1; then
      useradd \
        --system \
        --no-create-home \
        --shell /sbin/nologin \
        --home-dir /var/lib/supply-drop-bbs \
        --comment "Supply Drop BBS service account" \
        supply-drop
    fi

    # ── Data directory — writeable only by the service account ──────────────
    mkdir -p /var/lib/supply-drop-bbs
    chown supply-drop:supply-drop /var/lib/supply-drop-bbs
    chmod 750 /var/lib/supply-drop-bbs

    # ── Config directory — populated by the setup wizard ────────────────────
    mkdir -p /etc/supply-drop-bbs

    # ── Serial-port access — apply the packaged udev rule ───────────────────
    # 70-supply-drop-bbs.rules re-owns the radio's tty to the `supply-drop`
    # group so the service can open it regardless of the distro's default tty
    # group (dialout vs plugdev). The `supply-drop` group exists by now
    # (created above). Reload + trigger so an already-connected radio picks up
    # the new ownership without needing a replug. Idempotent on upgrades.
    if command -v udevadm >/dev/null 2>&1; then
      udevadm control --reload-rules || true
      udevadm trigger --subsystem-match=tty --action=add || true
    fi

    if command -v systemctl >/dev/null 2>&1; then
      systemctl daemon-reload || true

      if [ -n "$2" ]; then
        # ── Upgrade: service was stopped by prerm; restart it ───────────────
        systemctl restart supply-drop-bbs.service || true
        echo ""
        echo "Supply Drop BBS upgraded and restarted."
        echo ""
      else
        # ── Fresh install: enable but don't start — run setup first ─────────
        systemctl enable supply-drop-bbs.service || true
        echo ""
        echo "╔══════════════════════════════════════════════════════════════╗"
        echo "║              Supply Drop BBS installed                      ║"
        echo "╠══════════════════════════════════════════════════════════════╣"
        echo "║  1. Run the setup wizard to create your config:             ║"
        echo "║                                                              ║"
        echo "║       sudo supply-drop-bbs setup                            ║"
        echo "║                                                              ║"
        echo "║  2. Start the service:                                       ║"
        echo "║                                                              ║"
        echo "║       sudo systemctl start supply-drop-bbs                  ║"
        echo "╚══════════════════════════════════════════════════════════════╝"
        echo ""
      fi
    fi
    ;;
esac
